# --- JANKO BOT - KONFIGURACJA ---

# [DISCORD]
# Token bota z Discord Developer Portal
DISCORD_TOKEN=your_token_here

# Application ID (Client ID) bota
CLIENT_ID=your_client_id_here

# ID serwera testowego (opcjonalne, dla natychmiastowej synchronizacji komend)
GUILD_ID=your_guild_id_here

# [DATABASE]
# Format: mysql://user:password@host:port/database
# Jeśli używasz SparkedHost, upewnij się, że hasło jest URL-encoded
DATABASE_URL=mysql://user:password@host:3306/database
